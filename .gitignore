# ===========================================================================
# This repository holds our SWAT+ learning product only:
#   docs/, README.md, AGENTS.md, and workspace config.
# Everything ignored below is an upstream copy, a build artifact, or
# machine-specific state.
# ===========================================================================

# --- Upstream SWAT+ source tree -------------------------------------------
# Tracked as a git submodule (see .gitmodules). Do NOT ignore it.

# --- Visual Studio / Intel Fortran build output and IDE state -------------
/VSProj/**/x64/
/VSProj/**/.vs/
/VSProj/SWAT/enc_temp_folder/
*.user
*.suo
*.aps
*.opensdf
*.sdf

# --- Fortran compiler intermediates ---------------------------------------
# Normally produced under x64/; listed here as a safety net.
*.mod
*.obj
*__genmod.f90

# Local Visual Studio generated source copied from upstream templates.
/VSProj/SWAT/generated/main.f90

# --- CMake build directories ----------------------------------------------
build/

# --- OS / editor cruft ----------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
*.swp
*~

# --- Local agent / vault UI state -----------------------------------------
/.claude/
/docs/.claude/
/docs/.obsidian/workspace.json

# --- SWAT+ run outputs inside scenarios -----------------------------------
# Scenario inputs (file.cio, *.bsn, *.lum, *.pcp, ...) stay tracked.
/VSProj/SWAT/*.out
/VSProj/SWAT/erosion.txt
/VSProj/SWAT/Osu_1hru/*.out
/VSProj/SWAT/Osu_1hru/cs_*.ini
# Local zero-byte debug artifact documented in docs/input-files.md.
/VSProj/SWAT/Osu_1hru/recall_db.rec
# Existing sample outputs in other scenarios may stay tracked as fixtures.
# Do not add new run outputs unless they are intentionally curated examples.

# --- Python (docs/_tools generator) ---------------------------------------
__pycache__/
*.pyc
